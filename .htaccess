Options -Indexes
RewriteEngine On

# ═══════════════════════════════════════════════════════════════════════════════
# COMPRESSION
# ═══════════════════════════════════════════════════════════════════════════════

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/ld+json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/font-woff application/font-woff2 font/woff font/woff2
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/xml text/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/x-javascript
  AddOutputFilterByType BROTLI_COMPRESS application/json application/ld+json
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
  AddOutputFilterByType BROTLI_COMPRESS application/font-woff2 font/woff2
</IfModule>

# ═══════════════════════════════════════════════════════════════════════════════
# CACHING — dual strategy (mod_expires + mod_headers fallback)
# ═══════════════════════════════════════════════════════════════════════════════

<IfModule mod_expires.c>
  ExpiresActive On

  <FilesMatch "\.(js|css)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  ExpiresByType image/jpeg    "access plus 1 week"
  ExpiresByType image/png     "access plus 1 week"
  ExpiresByType image/webp    "access plus 1 week"
  ExpiresByType image/gif     "access plus 1 week"
  ExpiresByType image/svg+xml "access plus 1 week"

  ExpiresByType font/woff2              "access plus 2 weeks"
  ExpiresByType font/woff               "access plus 2 weeks"
  ExpiresByType application/font-woff2  "access plus 2 weeks"

  ExpiresByType image/x-icon              "access plus 1 week"
  ExpiresByType image/vnd.microsoft.icon  "access plus 1 week"
  ExpiresByType application/manifest+json "access plus 1 week"

  ExpiresByType text/html           "access plus 5 minutes"
  ExpiresByType application/json    "access plus 5 minutes"
  ExpiresByType application/ld+json "access plus 5 minutes"

</IfModule>

<IfModule mod_headers.c>

  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=604800, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=1209600, immutable"
  </FilesMatch>

  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>

  Header set Connection keep-alive
  Header unset Server
  Header unset X-Powered-By
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"

</IfModule>

# ═══════════════════════════════════════════════════════════════════════════════
# URL ROUTING
# ═══════════════════════════════════════════════════════════════════════════════

# ─── 0. SERVE DIRECTORY INDEX PAGES DIRECTLY ─────────────────────────────────
RewriteRule ^dog-grooming-in-pune/?$ /dog-grooming-in-pune/index.html [L]
RewriteRule ^cat-grooming-in-pune/?$ /cat-grooming-in-pune/index.html [L]

# ─── 1. .html → clean URL (301) ──────────────────────────────────────────────
# If anyone visits /wakad.html or /dog-grooming-in-pune/wakad.html,
# redirect them to the canonical clean URL.
# Prevents duplicate content Google could index from .html extension URLs.
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ─── 2. TRAILING SLASH REMOVAL (301 permanent) ───────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# ─── 3. CLEAN URL ROUTING (no .html in address bar) ──────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ /$1.html [L]

# ─── 4. SPA FALLBACK (for React routes) ──────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]
